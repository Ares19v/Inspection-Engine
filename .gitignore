# ==========================================
# Inspection Engine — .gitignore
# ==========================================

# ----- Python -----
venv/
env/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ----- Environment / Secrets -----
.env
.env.local
.env.*.local

# ----- Node.js / React -----
frontend/node_modules/
frontend/dist/
frontend/.vite/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- AI / YOLO Training Artifacts -----
# Keep: runs/detect/inspection_engine_final3/weights/best.pt  (trained weights)
# Drop: everything else in runs/ (logs, images, old runs)
DeepPCB-5/
model_training/pcb_data/
runs/detect/inspection_engine_final/
runs/detect/inspection_engine_final2/
runs/detect/inspection_engine_final3/weights/best.engine
runs/detect/inspection_engine_final3/[!w]*
runs/runs/

# Base YOLO pretrained weights (downloadable — not needed to run the project)
yolo*.pt

# TensorRT engine files — machine-specific, must be generated locally
*.engine

# ----- OS / Editor -----
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.suo
*.user
